# HTTP port the server binds to (Render injects PORT; 8080 is a safe default).
PORT=8080

# Secret used to sign JWTs. CHANGE THIS in production.
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me

# Where the in-memory JSON store + uploaded assets are persisted.
STORAGE_DIR=./data

# CORS — `*` allows any origin (editor runs on-device). To lock down, set a
# comma-separated list: https://editor.local,https://app.example.com
CORS_ORIGIN=*
